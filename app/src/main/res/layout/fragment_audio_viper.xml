<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:scrollbars="vertical"
    tools:context=".ui.fragments.AudioViperFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <!-- Master Switch -->
        <LinearLayout
            android:id="@+id/masterSwitchRow"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_viper"
                android:tint="#E65100"
                android:contentDescription="ViPER4Android"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ViPER4Android Master"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/v4aMasterSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#E65100"
                android:trackTint="#1E1E1E"
                android:checked="true"
                android:contentDescription="Enable V4A" />

        </LinearLayout>

        <!-- Section: DDC -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DDC — DRIVER CONFIGURATION"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/ddcRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/ddcSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DDC"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E"
                android:layout_marginEnd="12dp" />

            <Spinner
                android:id="@+id/ddcProfileSpinner"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:popupBackground="#111111"
                android:enabled="false" />

        </LinearLayout>

        <!-- Section: ViPER Bass -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIPER BASS"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/viperBassSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <Switch
                    android:id="@+id/viperBassSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ViPER Bass"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:thumbTint="#1565C0"
                    android:trackTint="#1E1E1E" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Bass Boost"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed" />

                <SeekBar
                    android:id="@+id/viperBassBoost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0"
                    android:progressBackgroundTint="#1E1E1E" />

                <TextView
                    android:id="@+id/viperBassBoostValue"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="50"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Frequency"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed" />

                <SeekBar
                    android:id="@+id/viperBassFreq"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="200"
                    android:progress="80"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0"
                    android:progressBackgroundTint="#1E1E1E" />

                <TextView
                    android:id="@+id/viperBassFreqValue"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="80Hz"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Section: FIR EQ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FIR EQUALIZER"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/firEqRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/firEqSwitch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FIR Equalizer"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E" />

        </LinearLayout>

        <!-- Section: Convolver -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONVOLVER"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/convolverSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/convolverSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Convolver"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/convolverFilePicker"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Choose IR File"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:id="@+id/convolverFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No file selected"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:maxLines="1"
                android:ellipsize="middle"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Section: Headphone Surround Plus -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEADPHONE SURROUND+"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/surroundSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/surroundSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP Surround+"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E"
                android:layout_marginEnd="12dp" />

            <SeekBar
                android:id="@+id/surroundLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="10"
                android:progress="5"
                android:progressTint="#1565C0"
                android:thumbTint="#1565C0"
                android:progressBackgroundTint="#1E1E1E" />

            <TextView
                android:id="@+id/surroundLevelValue"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:gravity="end" />

        </LinearLayout>

        <!-- Section: Dynamic System -->
        <LinearLayout
            android:id="@+id/dynamicSystemRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/dynamicSystemSwitch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dynamic System"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E" />

        </LinearLayout>

        <!-- Section: Tube Simulator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUBE SIMULATOR"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/tubeSimSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <Switch
                android:id="@+id/tubeSimSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tube Simulator"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:thumbTint="#1565C0"
                android:trackTint="#1E1E1E"
                android:layout_marginEnd="12dp" />

            <SeekBar
                android:id="@+id/tubeSimLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:progressTint="#1565C0"
                android:thumbTint="#1565C0"
                android:progressBackgroundTint="#1E1E1E" />

            <TextView
                android:id="@+id/tubeSimLevelValue"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:gravity="end" />

        </LinearLayout>

        <!-- Section: Output Volume -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OUTPUT VOLUME"
            android:textColor="#757575"
            android:textSize="10sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/outputVolumeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#111111"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_volume_up"
                android:tint="#757575"
                android:contentDescription="Volume"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/outputVolumeSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressTint="#E65100"
                android:thumbTint="#E65100"
                android:progressBackgroundTint="#1E1E1E" />

            <TextView
                android:id="@+id/outputVolumeValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:gravity="end"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
