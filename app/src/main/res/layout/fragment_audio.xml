<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    tools:context=".ui.audio.AudioFragment">

    <!-- Header row: backend badge aligned to the right -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#0D0D0D">

        <TextView
            android:id="@+id/tvBackendBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="12dp"
            android:text="● Základní"
            android:textColor="#757575"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            tools:text="● JDSP" />

    </FrameLayout>

    <!-- Profile cards row -->
    <HorizontalScrollView
        android:id="@+id/profileCardsScroll"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:scrollbars="none"
        android:background="#0D0D0D"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/profileCardsRow"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Flat -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileFlat"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Flat"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

            <!-- Bass+ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileBass"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Bass+"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

            <!-- Vocal -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileVocal"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Vocal"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

            <!-- Stage -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileStage"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Stage"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

            <!-- Night -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileNight"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Night"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

            <!-- Sport -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileSport"
                android:layout_width="140dp"
                android:layout_height="72dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Sport"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Auto-EQ banner -->
    <LinearLayout
        android:id="@+id/autoEqBanner"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1B5E20"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvAutoEqStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Auto EQ: Aktivní"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed" />

        <Button
            android:id="@+id/btnAutoEqToggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Vypnout"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:backgroundTint="#2E7D32"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#111111"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#1565C0"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V4A" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EQ" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profily" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zdroj" />

    </com.google.android.material.tabs.TabLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
