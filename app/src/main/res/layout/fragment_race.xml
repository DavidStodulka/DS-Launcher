<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    tools:context=".ui.fragments.RaceFragment">

    <!-- Mode Selector -->
    <LinearLayout
        android:id="@+id/raceModeSelector"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#111111"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/modePerformance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="PERFORMANCE"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.04"
            android:backgroundTint="#1565C0"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1E1E1E" />

        <Button
            android:id="@+id/modeLapTimer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="LAP TIMER"
            android:textColor="#757575"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.04"
            android:backgroundTint="#111111"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1E1E1E" />

        <Button
            android:id="@+id/modeGForce"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="G-FORCE"
            android:textColor="#757575"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.04"
            android:backgroundTint="#111111"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1565C0" />

    <!-- Performance Panel -->
    <LinearLayout
        android:id="@+id/performancePanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left: measurement type + controls -->
        <LinearLayout
            android:layout_width="240dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#111111"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEASUREMENT"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Measurement type buttons -->
            <Button
                android:id="@+id/btn0to100"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="0 – 100 km/h"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1565C0"
                android:layout_marginBottom="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn0to200"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="0 – 200 km/h"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:layout_marginBottom="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn80to120"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="80 – 120 km/h"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:layout_marginBottom="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btnBraking"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Braking Distance"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:layout_marginBottom="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/measureCustom"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Custom Range..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:layout_marginBottom="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Best / Avg results row -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BEST"
                        android:textColor="#757575"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/bestResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--.-s"
                        android:textColor="#2E7D32"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        tools:text="5.8s" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG"
                        android:textColor="#757575"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/avgResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--.-s"
                        android:textColor="#F9A825"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        tools:text="6.1s" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1E1E1E" />

        <!-- Center: Result display + Start/Stop -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMeasurementState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 – 100 km/h"
                android:textColor="#757575"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="8dp"
                tools:text="0 – 100 km/h" />

            <!-- Large result display -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0s"
                android:textColor="#FFFFFF"
                android:textSize="72sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"
                tools:text="5.84s" />

            <!-- Start / Stop button -->
            <Button
                android:id="@+id/startStopButton"
                android:layout_width="180dp"
                android:layout_height="80dp"
                android:text="START"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:backgroundTint="#2E7D32"
                android:elevation="4dp" />

            <!-- HUD launch button (visible during active measurement) -->
            <Button
                android:id="@+id/btnLaunchHUD"
                android:layout_width="180dp"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="OPEN HUD"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#E65100"
                android:visibility="gone"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Secondary result details -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvMaxSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- km/h"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginEnd="16dp"
                    tools:text="102.3 km/h" />

                <TextView
                    android:id="@+id/tvAvgAccel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- m/s²"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    tools:text="4.12 m/s²" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1E1E1E" />

        <!-- Right: results history -->
        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#111111"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION RESULTS"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSessions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                tools:listitem="@layout/item_race_result"
                tools:itemCount="6" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Clear Session"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#1E1E1E"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
