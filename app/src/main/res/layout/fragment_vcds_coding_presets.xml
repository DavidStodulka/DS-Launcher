<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    tools:context=".ui.fragments.VcdsCodingPresetsFragment">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/presetsToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CODING PRESETS"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.06" />

        <ImageButton
            android:id="@+id/btnImportPreset"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_import"
            android:background="@drawable/control_btn_bg"
            android:tint="#757575"
            android:contentDescription="Import preset"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnAddPreset"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/control_btn_bg"
            android:tint="#1565C0"
            android:contentDescription="Add new preset"
            android:padding="8dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E" />

    <!-- Warning banner -->
    <LinearLayout
        android:id="@+id/warningBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1400"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_warning"
            android:tint="#F9A825"
            android:contentDescription="Warning"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coding changes may affect vehicle behavior. Apply only verified presets."
            android:textColor="#F9A825"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <!-- Presets RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/codingPresetsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:listitem="@layout/item_coding_preset"
        tools:itemCount="8" />

</LinearLayout>
