<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    tools:context=".ui.fragments.VcdsLongCodingFragment">

    <!-- ECU Selection Row -->
    <LinearLayout
        android:id="@+id/ecuSelectionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ECU:"
            android:textColor="#757575"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/ecuSpinnerLongCoding"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_bg"
            android:popupBackground="#111111"
            tools:entries="@array/ecu_list" />

        <Button
            android:id="@+id/btnReadCoding"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="READ"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-condensed"
            android:backgroundTint="#1565C0"
            android:layout_marginStart="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E" />

    <!-- Main content: scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Current Coding String -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT CODING STRING"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/currentCodingString"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="00 00 00 00 00 00 00 00"
                android:textColor="#FFFFFF"
                android:textColorHint="#757575"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:inputType="text"
                android:background="@drawable/input_bg"
                android:padding="10dp"
                android:singleLine="true"
                android:layout_marginBottom="16dp"
                tools:text="03 E0 00 01 A0 00 FF 00" />

            <!-- Byte / Bit Editor section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BIT EDITOR"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.08" />

                <Spinner
                    android:id="@+id/bytePageSpinner"
                    android:layout_width="120dp"
                    android:layout_height="32dp"
                    android:background="@drawable/spinner_bg"
                    android:popupBackground="#111111" />

            </LinearLayout>

            <!-- Bit editor grid container: 8 columns header row -->
            <LinearLayout
                android:id="@+id/bitEditorHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 7"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 6"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 5"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 4"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 3"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 2"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 1"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit 0"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <!-- Label column -->
                <View
                    android:layout_width="120dp"
                    android:layout_height="1dp" />

            </LinearLayout>

            <!-- Bit Grid: dynamically populated by adapter; placeholder rows shown in tools preview -->
            <LinearLayout
                android:id="@+id/bitEditorGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Byte 0 row (representative static row for layout preview) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#111111"
                    android:layout_marginBottom="2dp">

                    <CheckBox
                        android:id="@+id/bit7_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit6_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit5_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit4_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit3_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit2_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit1_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <CheckBox
                        android:id="@+id/bit0_byte0"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:buttonTint="#1565C0" />

                    <!-- Bit label -->
                    <TextView
                        android:id="@+id/bitLabelByte0"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Byte 0"
                        android:textColor="#757575"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:paddingStart="8dp"
                        tools:text="Byte 0 – Lighting" />

                </LinearLayout>

            </LinearLayout>

            <!-- Preview section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E1E1E"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW CODING STRING PREVIEW"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/newCodingPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-- -- -- -- -- -- -- --"
                android:textColor="#1565C0"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:background="@drawable/preview_bg"
                android:padding="10dp"
                android:layout_marginBottom="16dp"
                tools:text="03 E0 01 01 A0 00 FF 00" />

            <!-- Save / Restore buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRestoreCoding"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="RESTORE ORIGINAL"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#C62828"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnSaveCoding"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="WRITE CODING"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#1565C0" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
