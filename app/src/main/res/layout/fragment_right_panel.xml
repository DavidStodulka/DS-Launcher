<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- RPM Gauge + Speed Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- RPM Circular Gauge (custom view placeholder) -->
            <View
                android:id="@+id/rpmGaugeView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="#1E1E1E"
                tools:background="#1565C0" />

            <!-- Speed Numeric -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/speedNumeric"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:gravity="center"
                    tools:text="87" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- Coolant Temperature -->
        <LinearLayout
            android:id="@+id/coolantTempRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/coolantIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_thermometer"
                android:tint="#1565C0"
                android:contentDescription="Coolant temperature" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Coolant"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/coolantTempValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                tools:text="87" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" °C"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- Battery Voltage -->
        <LinearLayout
            android:id="@+id/batteryVoltageRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/batteryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_battery"
                android:tint="#2E7D32"
                android:contentDescription="Battery voltage" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Battery"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/batteryVoltageValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                tools:text="14.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" V"
                android:textColor="#757575"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- AC Panel -->
        <LinearLayout
            android:id="@+id/acPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLIMATE"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <!-- Temperature Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/acTempDown"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_remove"
                    android:background="@drawable/control_btn_bg"
                    android:tint="#FFFFFF"
                    android:contentDescription="Decrease temperature"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/acTempSetpoint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="22.0°C"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:gravity="center"
                    tools:text="21.5°C" />

                <ImageButton
                    android:id="@+id/acTempUp"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/control_btn_bg"
                    android:tint="#FFFFFF"
                    android:contentDescription="Increase temperature"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- Fan Speed Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_fan"
                    android:tint="#757575"
                    android:contentDescription="Fan speed" />

                <SeekBar
                    android:id="@+id/acFanSpeed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="7"
                    android:progress="3"
                    android:progressTint="#1565C0"
                    android:thumbTint="#1565C0"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/acFanSpeedValue"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    tools:text="4" />

            </LinearLayout>

            <!-- AC Mode Icons Row -->
            <LinearLayout
                android:id="@+id/acModeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/acModeAc"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_ac"
                    android:background="@drawable/mode_btn_bg_selected"
                    android:tint="#FFFFFF"
                    android:contentDescription="AC on/off"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp" />

                <ImageButton
                    android:id="@+id/acModeRecirculate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_recirculate"
                    android:background="@drawable/mode_btn_bg"
                    android:tint="#757575"
                    android:contentDescription="Recirculate"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp" />

                <ImageButton
                    android:id="@+id/acModeDefrost"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_defrost"
                    android:background="@drawable/mode_btn_bg"
                    android:tint="#757575"
                    android:contentDescription="Defrost"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp" />

                <ImageButton
                    android:id="@+id/acModeSync"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_sync"
                    android:background="@drawable/mode_btn_bg"
                    android:tint="#757575"
                    android:contentDescription="Sync temperature"
                    android:padding="8dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- Door/Belt Status 2x2 Grid -->
        <LinearLayout
            android:id="@+id/doorBeltStatusSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOORS"
                android:textColor="#757575"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <!-- Row 1: FL, FR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/doorIndicatorFL"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#2E7D32" />

                    <TextView
                        android:id="@+id/doorLabelFL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FL"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginStart="6dp" />

                    <ImageView
                        android:id="@+id/beltIndicatorFL"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_seatbelt"
                        android:tint="#2E7D32"
                        android:contentDescription="FL seatbelt"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/doorIndicatorFR"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#2E7D32" />

                    <TextView
                        android:id="@+id/doorLabelFR"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FR"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginStart="6dp" />

                    <ImageView
                        android:id="@+id/beltIndicatorFR"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_seatbelt"
                        android:tint="#2E7D32"
                        android:contentDescription="FR seatbelt"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: RL, RR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/doorIndicatorRL"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#2E7D32" />

                    <TextView
                        android:id="@+id/doorLabelRL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RL"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginStart="6dp" />

                    <ImageView
                        android:id="@+id/beltIndicatorRL"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_seatbelt"
                        android:tint="#757575"
                        android:contentDescription="RL seatbelt"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/doorIndicatorRR"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#2E7D32" />

                    <TextView
                        android:id="@+id/doorLabelRR"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RR"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginStart="6dp" />

                    <ImageView
                        android:id="@+id/beltIndicatorRR"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_seatbelt"
                        android:tint="#757575"
                        android:contentDescription="RR seatbelt"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
