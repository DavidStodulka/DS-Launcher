<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- Session header row -->
    <LinearLayout
        android:id="@+id/sessionHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSessionDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--.--.---- --:--"
            android:textColor="#BDBDBD"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvSessionDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#BDBDBD"
            android:textSize="13sp"
            android:layout_marginStart="16dp" />

        <TextView
            android:id="@+id/tvSessionDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0 km"
            android:textColor="#BDBDBD"
            android:textSize="13sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Radar chart -->
    <com.caros.views.RadarChartView
        android:id="@+id/radarChartView"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/sessionHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scores row -->
    <LinearLayout
        android:id="@+id/scoresRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/radarChartView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Eco score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvEcoScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#4CAF50"
                android:textSize="28sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvEcoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eco"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Sport score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvSportScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF5722"
                android:textSize="28sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvSportLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sport"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Mechanical score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvMechanicalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#1565C0"
                android:textSize="28sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvMechanicalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Technika"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Smoothness score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvSmoothnessScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF9800"
                android:textSize="28sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvSmoothnessLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plynulost"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Export button -->
    <Button
        android:id="@+id/btnExport"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:text="Exportovat CSV"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="#1E1E1E"
        app:layout_constraintTop_toBottomOf="@id/scoresRow"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp" />

    <!-- Recommendations text -->
    <ScrollView
        android:id="@+id/recommendationsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnExport"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#BDBDBD"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
